VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only (MCP server, migration scripts). Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection (used by scripts/migrate.ts).
SUPABASE_DB_PASSWORD=
# Optional: full Postgres connection string override. If unset, scripts build a direct (IPv6) URL.
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Resend API key — used as SMTP password in Supabase Auth + reserved for server-side use.
RESEND_API_KEY=
